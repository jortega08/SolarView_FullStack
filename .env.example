# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# PostgreSQL
POSTGRES_DB=solarview
POSTGRES_USER=solarview
POSTGRES_PASSWORD=change-this-password
POSTGRES_HOST=postgres
