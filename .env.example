# ============================================================
# Soleim - Template de Variables de Entorno
# ============================================================
# Copiar este archivo como .env y completar los valores reales.
# El archivo .env esta ignorado por git (ver .gitignore).

# Django
SECRET_KEY=cambiar-por-una-clave-secreta-segura-en-produccion
DEBUG=False
ALLOWED_HOSTS=django,localhost,127.0.0.1,0.0.0.0

# PostgreSQL
POSTGRES_DB=soleim
POSTGRES_USER=soleim
POSTGRES_PASSWORD=cambiar_por_password_seguro

# MQTT
MQTT_USER=soleim
MQTT_PASS=cambiar_por_password_mqtt_seguro

# CORS (origenes permitidos separados por coma)
CORS_ALLOWED_ORIGINS=http://localhost:5174,http://localhost:5173
